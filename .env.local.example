# Supabase Configuration
# Replace with your actual Supabase project URL (e.g. https://xxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url

# Replace with your actual Supabase Anon Key (found in Settings -> API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Replace with your actual Supabase Service Role Key (used for backend administration/triggers)
# WARNING: Keep this secret, do not expose on the client!
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# OpenRouter Configuration
# Replace with your actual OpenRouter API Key for free AI summarization, tags, and highlights
OPENROUTER_API_KEY=your-openrouter-api-key

# Optional: Override the default free model (e.g. meta-llama/llama-3.3-70b-instruct:free or openrouter/free)
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
